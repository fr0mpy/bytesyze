{
  "name": "bytesyze-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "esbuild": "0.21.5"
    }
  },
  "scripts": {
    "clean:ports": "for port in 3000 5173; do lsof -ti :$port | xargs kill -9 2>/dev/null; done; echo 'Ports cleared'",
    "clean:next": "rm -rf apps/web/.next",
    "predev": "pnpm clean:ports && pnpm clean:next",
    "dev": "turbo dev --no-daemon",
    "dev:web": "turbo dev --no-daemon --filter @bytesyze/web",
    "dev:harness": "turbo dev --no-daemon --filter @bytesyze-ui/harness",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.0.0",
    "next": "^15.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
